<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="@string/app_name"
        android:theme="@style/PluginTheme">

        <meta-data
            android:name="plugin.id"
            android:value="org.appdevforall.templatizeproject" />

        <meta-data
            android:name="plugin.name"
            android:value="Templatize Project" />

        <meta-data
            android:name="plugin.version"
            android:value="${pluginVersion}" />

        <meta-data
            android:name="plugin.description"
            android:value="Converts an Android Studio project into a Code On the Go (.cgt) template, and can install it directly into the IDE." />

        <meta-data
            android:name="plugin.author"
            android:value="App Dev For All" />

        <meta-data
            android:name="plugin.min_ide_version"
            android:value="1.0.0" />

        <meta-data
            android:name="plugin.permissions"
            android:value="filesystem.read,filesystem.write,project.structure" />

        <meta-data
            android:name="plugin.main_class"
            android:value="org.appdevforall.templatizeproject.TemplatizeProjectPlugin" />

        <meta-data
            android:name="plugin.icon_day"
            android:value="assets/icon_day.png" />

        <meta-data
            android:name="plugin.icon_night"
            android:value="assets/icon_night.png" />

        <meta-data
            android:name="plugin.sidebar_items"
            android:value="1" />

    </application>

</manifest>
